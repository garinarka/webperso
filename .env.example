# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=your_site_url

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ─── Form endpoint ────────────────────────────────────────────────────────────────
# I usually use Formspree for contact forms, but you can swap with any service (e.g. Getform, Basin, custom API)
# Get from: https://formspree.io/dashboard → Create Form → Copy Endpoint URL
NEXT_PUBLIC_FORM_ENDPOINT=your_form_endpoint

# ─── Redis (Vercel KV) ────────────────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → KV → Connect
KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token

# If NOT on Vercel, use Upstash instead (same @vercel/kv API):
# Install: pnpm remove @vercel/kv && pnpm add @upstash/redis
# Then update lib/redis.ts to: import { Redis } from '@upstash/redis'
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── Blog engagement ─────────────────────────────────────────────────────────
# Set to "true" to auto-approve all comments (skip moderation queue)
AUTO_APPROVE_COMMENTS=false

# Admin secret for comment moderation API
# Usage: curl -H "x-admin-secret: your_secret" -X PATCH ... or use in admin API calls
# Generate a long random string for this, e.g. using https://passwordsgenerator.net/ or `openssl rand -base64 32`
ADMIN_SECRET=change_this_to_a_long_random_string

# ─── Social Links ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN=https://linkedin.com/in/yourusername
NEXT_PUBLIC_TWITTER=https://twitter.com/yourusername

# ─── Analytics ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Generate a long random string for AUTH_SECRET using 'npx auth secret'
AUTH_SECRET=your_auth_secret
# Set to your deployed URL (e.g. Vercel URL) for correct OAuth callback URLs
AUTH_URL=https://your-deployed-url.com

# For Google OAuth, get these from Google Cloud Console → Credentials → Create Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# For Resend email sending, get the API key from https://resend.com/dashboard → API Keys
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=onboarding@resend.dev